CC = wcc386 -bt=nt -q
LD = wlink option quiet

CFLAGS = -i=../include -d_LARPSAVER
LDFLAGS = system nt_dll
EXE_CFLAGS = -i=../include
EXE_LDFLAGS = system nt

all: larpsaver.lib
examples: opengl_example.exe

opengl_example.exe: win32.obj larpsaver.obj opengl_example.obj
	$(LD) $(EXE_LDFLAGS) name $@ file opengl_example.obj file win32.obj file larpsaver.obj

larpsaver.lib: win32.obj larpsaver.obj
	$(LD) $(LDFLAGS) name $@ file win32.obj file larpsaver.obj library opengl32.lib library gdi32.lib library user32.lib library advapi32.lib

opengl_example.obj: ../examples/opengl_example.c
	$(CC) $(EXE_CFLAGS) -fo=$@ -d_WIN32 ../examples/opengl_example.c

win32.obj: ../src/platform/win32.c
	$(CC) $(CFLAGS) -fo=$@ ../src/platform/win32.c
larpsaver.obj: ../src/larpsaver.c
	$(CC) $(CFLAGS) -fo=$@ ../src/larpsaver.c
